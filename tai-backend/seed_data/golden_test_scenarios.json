[
  {
    "scenario_id": "SCN-001",
    "title": "Kesin fiyat limiti altında stoklu kablosuz okuyucu ekleme",
    "channel": "mobile",
    "customer_id": "CUST-ANK-002",
    "quote_id": "Q-1002",
    "user_message": "9.000 TL altında, stokta olan kablosuz QR barkod okuyucu ekler misin?",
    "expected_tool_calls": [
      {
        "name": "search_products",
        "must_match": {
          "max_price_try": 9000,
          "in_stock_only": true
        }
      },
      {
        "name": "add_to_quote",
        "must_match": {
          "product_id": "PRD-BC-110",
          "quantity": 1
        }
      },
      {
        "name": "get_quote",
        "must_match": {
          "quote_id": "Q-1002"
        }
      }
    ],
    "expected_sources": [
      "PRD-BC-110",
      "KNE-PRICE-001"
    ],
    "must_not_recommend": [
      "PRD-BC-120"
    ],
    "quote_assertion": "Q-1002 içinde PRD-BC-110 aktif kalemi miktar 1 olarak bulunmalıdır."
  },
  {
